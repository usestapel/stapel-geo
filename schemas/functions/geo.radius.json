{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "geo.radius",
  "description": "Every location within radius_km of a point (not top-K), ascending exact haversine distance. Returns {\"results\": [{uuid, name, country, geohash, distance_km}, ...]}. Served by the configured search backend (STAPEL_GEO[\"SEARCH_BACKEND\"]).",
  "type": "object",
  "properties": {
    "lat": {"type": "number", "minimum": -90, "maximum": 90, "description": "Latitude of the circle centre."},
    "lon": {"type": "number", "minimum": -180, "maximum": 180, "description": "Longitude of the circle centre."},
    "radius_km": {"type": "number", "exclusiveMinimum": 0, "maximum": 20038, "description": "Circle radius in kilometres."},
    "limit": {"type": "integer", "minimum": 1, "description": "Maximum number of results."}
  },
  "required": ["lat", "lon", "radius_km"],
  "additionalProperties": false
}
