  "components": {
    "schemas": {
      "GeocodeFeature": {
        "type": "object",
        "description": "A single geocoded result feature.",
        "properties": {
          "type": {
            "type": "string",
            "description": "GeoJSON type",
            "example": "Feature"
          },
          "geometry": {
            "allOf": [
              {
                "$ref": "#/components/schemas/GeocodeGeometry"
              }
            ],
            "description": "Point geometry with coordinates"
          },
          "properties": {
            "allOf": [
              {
                "$ref": "#/components/schemas/GeocodeProperties"
              }
            ],
            "description": "Place properties (name, address components, OSM data)"
          }
        },
        "required": [
          "geometry",
          "properties",
          "type"
        ]
      },
      "GeocodeGeometry": {
        "type": "object",
        "description": "GeoJSON point geometry.",
        "properties": {
          "type": {
            "type": "string",
            "description": "Geometry type",
            "example": "Point"
          },
          "coordinates": {
            "type": "array",
            "items": {
              "type": "number",
              "format": "double"
            },
            "description": "[longitude, latitude]",
            "example": [
              13.38333,
              52.51667
            ]
          }
        },
        "required": [
          "coordinates",
          "type"
        ]
      },
      "GeocodeProperties": {
        "type": "object",
        "description": "Properties of a geocoded feature.",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true,
            "description": "Place name",
            "example": "Berlin"
          },
          "country": {
            "type": "string",
            "nullable": true,
            "description": "Country name",
            "example": "Germany"
          },
          "countrycode": {
            "type": "string",
            "nullable": true,
            "description": "ISO 3166-1 alpha-2 code",
            "example": "DE"
          },
          "osm_key": {
            "type": "string",
            "nullable": true,
            "description": "OSM tag key",
            "example": "place"
          },
          "osm_value": {
            "type": "string",
            "nullable": true,
            "description": "OSM tag value",
            "example": "city"
          },
          "osm_type": {
            "type": "string",
            "nullable": true,
            "description": "OSM element type (N/W/R)",
            "example": "R"
          },
          "osm_id": {
            "type": "integer",
            "nullable": true,
            "description": "OSM element ID",
            "example": 240109189
          },
          "state": {
            "type": "string",
            "nullable": true,
            "description": "State or region",
            "example": "Brandenburg"
          },
          "county": {
            "type": "string",
            "nullable": true,
            "description": "County name",
            "example": "Kreisfreie Stadt Berlin"
          },
          "city": {
            "type": "string",
            "nullable": true,
            "description": "City name",
            "example": "Berlin"
          },
          "district": {
            "type": "string",
            "nullable": true,
            "description": "District or suburb",
            "example": "Mitte"
          },
          "street": {
            "type": "string",
            "nullable": true,
            "description": "Street name",
            "example": "Unter den Linden"
          },
          "housenumber": {
            "type": "string",
            "nullable": true,
            "description": "House number",
            "example": 1
          },
          "postcode": {
            "type": "string",
            "nullable": true,
            "description": "Postal code",
            "example": 10117
          },
          "extent": {
            "type": "array",
            "items": {
              "type": "number",
              "format": "double"
            },
            "nullable": true,
            "description": "Bounding box [minLon, minLat, maxLon, maxLat]",
            "example": [
              13.08,
              52.33,
              13.76,
              52.68
            ]
          }
        }
      },
      "GeocodeResponse": {
        "type": "object",
        "description": "GeoJSON FeatureCollection with geocoding results.",
        "properties": {
          "type": {
            "type": "string",
            "description": "GeoJSON type",
            "example": "FeatureCollection"
          },
          "features": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GeocodeFeature"
            },
            "description": "List of geocoded features"
          }
        }
      },
      "Location": {
        "type": "object",
        "description": "Full Location representation — a flat point plus tree metadata.",
        "properties": {
          "id": {
            "type": "integer",
            "readOnly": true
          },
          "uuid": {
            "type": "string",
            "format": "uuid",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "nullable": true,
            "maxLength": 100
          },
          "type": {
            "type": "string",
            "nullable": true,
            "maxLength": 100
          },
          "country": {
            "type": "string",
            "maxLength": 255
          },
          "lat": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "lon": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "geohash": {
            "type": "string",
            "readOnly": true,
            "nullable": true
          },
          "tn_parent": {
            "type": "integer",
            "nullable": true,
            "title": "Parent"
          },
          "display_name_narrow": {
            "type": "string",
            "readOnly": true
          },
          "display_name_broad": {
            "type": "string",
            "readOnly": true
          }
        },
        "required": [
          "display_name_broad",
          "display_name_narrow",
          "geohash",
          "id",
          "uuid"
        ]
      },
      "LocationCompact": {
        "type": "object",
        "description": "Lightweight Location representation; nearby adds distance_km.",
        "properties": {
          "id": {
            "type": "integer",
            "readOnly": true
          },
          "uuid": {
            "type": "string",
            "format": "uuid",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "nullable": true,
            "maxLength": 100
          },
          "type": {
            "type": "string",
            "nullable": true,
            "maxLength": 100
          },
          "country": {
            "type": "string",
            "maxLength": 255
          },
          "geohash": {
            "type": "string",
            "nullable": true,
            "maxLength": 12
          },
          "tn_parent": {
            "type": "integer",
            "nullable": true,
            "title": "Parent"
          },
          "display_name_narrow": {
            "type": "string",
            "maxLength": 255
          },
          "display_name_broad": {
            "type": "string",
            "maxLength": 255
          },
          "distance_km": {
            "type": "number",
            "format": "double",
            "readOnly": true,
            "nullable": true
          }
        },
        "required": [
          "distance_km",
          "id",
          "uuid"
        ]
      },
      "PatchedLocation": {
        "type": "object",
        "description": "Full Location representation — a flat point plus tree metadata.",
        "properties": {
          "id": {
            "type": "integer",
            "readOnly": true
          },
          "uuid": {
            "type": "string",
            "format": "uuid",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "nullable": true,
            "maxLength": 100
          },
          "type": {
            "type": "string",
            "nullable": true,
            "maxLength": 100
          },
          "country": {
            "type": "string",
            "maxLength": 255
          },
          "lat": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "lon": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "geohash": {
            "type": "string",
            "readOnly": true,
            "nullable": true
          },
          "tn_parent": {
            "type": "integer",
            "nullable": true,
            "title": "Parent"
          },
          "display_name_narrow": {
            "type": "string",
            "readOnly": true
          },
          "display_name_broad": {
