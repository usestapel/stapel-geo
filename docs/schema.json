  "paths": {
    "/geo/api/v1/geocoding/reverse": {
      "get": {
        "operationId": "geo_api_v1_geocoding_reverse_retrieve",
        "description": "Reverse geocoding — coordinates to address.\n\n**Permissions:** `IsNotAnonymousUser`",
        "summary": "Reverse geocode coordinates",
        "parameters": [
          {
            "in": "query",
            "name": "lang",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "lat",
            "schema": {
              "type": "number",
              "format": "float"
            },
            "required": true
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "lon",
            "schema": {
              "type": "number",
              "format": "float"
            },
            "required": true
          }
        ],
        "tags": [
          "Geocoding"
        ],
        "security": [
          {
            "JWTCookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GeocodeResponse"
                },
                "examples": {
                  "GeocodeResponse": {
                    "value": {
                      "type": "FeatureCollection"
                    }
                  }
                }
              }
            },
            "description": ""
          }
        }
      }
    },
    "/geo/api/v1/geocoding/search": {
      "get": {
        "operationId": "geo_api_v1_geocoding_search_retrieve",
        "description": "Forward geocoding — search places by free-text query.\n\n**Permissions:** `IsNotAnonymousUser`",
        "summary": "Search places by text",
        "parameters": [
          {
            "in": "query",
            "name": "lang",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "q",
            "schema": {
              "type": "string"
            },
            "description": "Search query",
            "required": true
          }
        ],
        "tags": [
          "Geocoding"
        ],
        "security": [
          {
            "JWTCookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GeocodeResponse"
                },
                "examples": {
                  "GeocodeResponse": {
                    "value": {
                      "type": "FeatureCollection"
                    }
                  }
                }
              }
            },
            "description": ""
          }
        }
      }
    },
    "/geo/api/v1/geocoding/structured": {
      "get": {
        "operationId": "geo_api_v1_geocoding_structured_retrieve",
        "description": "Structured address search — search by address components.\n\n**Permissions:** `IsNotAnonymousUser`",
