    "/geo/api/v1/locations/by-parent/{parent_id}/": {
      "get": {
        "operationId": "geo_api_v1_locations_by_parent_list",
        "summary": "Children of a location",
        "parameters": [
          {
            "in": "path",
            "name": "parent_id",
            "schema": {
              "type": "string",
              "pattern": "^\\d+$"
