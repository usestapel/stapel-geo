    "/geo/api/v1/locations/validate-uuid/{uuid}/": {
      "get": {
        "operationId": "geo_api_v1_locations_validate_uuid_retrieve",
        "parameters": [
          {
            "in": "path",
            "name": "uuid",
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true
          }
        ],
        "tags": [
